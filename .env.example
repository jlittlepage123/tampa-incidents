# Server configuration
PORT=3000
NODE_ENV=production

# Database path (relative to project root)
DB_PATH=./data/incidents.db

# Feed fetch interval in minutes
FETCH_INTERVAL_MINUTES=60

# Zone configuration — comma-separated grid numbers
# GRID_RED=152
# GRID_YELLOW=120,136,151,153,157,158,159

# Map center — defaults to Tampa Police Grid 152 centroid
# MAP_CENTER_LAT=27.947281
# MAP_CENTER_LNG=-82.499440
# MAP_CENTER_ZOOM=14
